{
    "name": "woweb/laravel-openproduct",
    "description": "Laravel wrapper for Open Product",
    "type": "library",
    "license": "EUPL-1.2",
    "homepage": "https://github.com/WowebNL/laravel-openproduct",
    "support": {
        "source": "https://github.com/WowebNL/laravel-openproduct"
    },
    "authors": [
        {
            "name": "Michel Verhoeven",
            "email": "info@woweb.nl"
        }
    ],
    "require": {
        "php": "^8.2",
        "guzzlehttp/guzzle": "^7.2",
        "illuminate/http": "^10.0|^11.0|^12.0",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "illuminate/validation": "^10.0|^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0",
        "phpunit/phpunit": "^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "Woweb\\Openproduct\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Woweb\\Openproduct\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Woweb\\Openproduct\\OpenProductServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
